# Copy to .env and fill in. The live "AI scam check" calls the Anthropic API
# from the backend (the key is never exposed to the browser).

# Required for the live AI scam check.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model used for analysis.
# Defaults to claude-sonnet-4-6 (good fraud reasoning, fast).
# For cheaper/faster classification you can use claude-haiku-4-5-20251001.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: port for the production Express server (npm start).
PORT=3000
