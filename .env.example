# Copy to .env and fill in. The live "AI scam check" calls an LLM provider from
# the backend (the key is never exposed to the browser).
#
# Pick ONE provider. If NVIDIA_API_KEY is set it is used automatically;
# otherwise ANTHROPIC_API_KEY is used. Force a provider with LLM_PROVIDER.

# Optional: force a provider — "nvidia" or "anthropic". Auto-detected if unset.
# LLM_PROVIDER=nvidia

# ── NVIDIA (build.nvidia.com — OpenAI-compatible) ────────────────────────────
# Get a key at https://build.nvidia.com (free tier available).
NVIDIA_API_KEY=nvapi-...
# Optional: any model id from build.nvidia.com.
# Default: meta/llama-3.3-70b-instruct
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# ── Anthropic (alternative) ──────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: port for the production Express server (npm start).
PORT=3000
